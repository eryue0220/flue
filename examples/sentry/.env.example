# Sentry — all optional. Without SENTRY_DSN the app runs unchanged with the
# Sentry SDK disabled; every capture and log call is a no-op.
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
# SENTRY_RELEASE=

# Tracing: 0 (the integration default) sends errors and logs only. This
# example's .env keeps 1.0 so every conversation produces a full trace.
SENTRY_TRACES_SAMPLE_RATE=1.0

# Content capture: model and tool inputs/outputs stay out of traces unless
# explicitly enabled. Timing, token usage, and correlation ids always flow.
SENTRY_AI_RECORD_INPUTS=false
SENTRY_AI_RECORD_OUTPUTS=false

# The demo agents use Anthropic models.
ANTHROPIC_API_KEY=
